# Railway: add each line as a Variable (same names, paste values).
# Local: copy to ".env" for flask run — cp .env.example .env

# --- Required: same Postgres URL on client + admin + signaler ---
DATABASE_URL=

# --- Required: same key on all three if you use encrypted columns ---
CHAT_DB_ENCRYPTION_KEY=

# --- Client session signing ---
CLIENT_SECRET_KEY=

# --- Public HTTPS URLs (no trailing slash) ---
ADMIN_PUBLIC_BASE_URL=
CLIENT_PUBLIC_BASE_URL=

# --- Optional: separate Socket.IO host (deploy deploy-signaler); leave empty to use this service only ---
SIGNALING_PUBLIC_URL=

# --- If SIGNALING_PUBLIC_URL is set, allow browser origin (usually = CLIENT_PUBLIC_BASE_URL) ---
SOCKETIO_CORS_ORIGINS=

# --- Recommended when using a separate signaler or multiple workers (Railway Redis plugin) ---
REDIS_URL=
SOCKETIO_MESSAGE_QUEUE=

# --- Marks production cookies / proxy (Railway sets RAILWAY_ENVIRONMENT too) ---
ENVIRONMENT=production
