# Railway: add each line as a Variable.
# Must match client: DATABASE_URL, CHAT_DB_ENCRYPTION_KEY, CLIENT_SECRET_KEY

DATABASE_URL=
CHAT_DB_ENCRYPTION_KEY=
CLIENT_SECRET_KEY=

# Origins allowed to open Socket.IO from the browser (comma-separated). Usually your client URL.
SOCKETIO_CORS_ORIGINS=

# Same Redis on client + signaler if you split services or scale workers
REDIS_URL=
SOCKETIO_MESSAGE_QUEUE=

ENVIRONMENT=production
