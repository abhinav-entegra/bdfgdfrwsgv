# Copy to .env locally. On Railway, set these in each service's Variables.

# Same on every service that reads encrypted columns
CHAT_DB_ENCRYPTION_KEY=

# --- Unified app (unified_app.py) — portal, Client + Admin login, one deploy ---

SECRET_KEY=
CLIENT_PUBLIC_BASE_URL=https://your-app.up.railway.app

# --- Database (pick ONE approach or data is lost on every Railway redeploy) ---

# A) Persistent SQLite on a mounted volume (Railway: add Volume, mount path e.g. /data)
# SQLITE_DATA_DIR=/data
# → creates /data/unified_chat.db (survives redeploys). Put chat.db in /data for auto-import.

# B) PostgreSQL (Railway Postgres plugin → DATABASE_URL is set automatically)
# UNIFIED_USE_POSTGRES=true
# Do NOT set SQLITE_DATA_DIR when using Postgres.

# Legacy SQLite merge (SQLite mode only): optional file path, or place chat.db next to DB / in SQLITE_DATA_DIR
# LEGACY_SQLITE_FILE=/data/chat.db
# FORCE_LEGACY_MERGE=1

# --- Legacy split deploy (app.py + client_app.py) ---
# DATABASE_URL=postgresql://...
# ADMIN_SECRET_KEY=
# CLIENT_SECRET_KEY=

# Optional: signaling / Socket.IO
SIGNALING_PUBLIC_URL=
SOCKETIO_CORS_ORIGINS=https://your-app.up.railway.app
# REDIS_URL=
# SOCKETIO_MESSAGE_QUEUE=${REDIS_URL}

# ENVIRONMENT=production
