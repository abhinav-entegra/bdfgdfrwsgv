# Copy to .env locally. On Railway, set these in each service's Variables.

# --- Shared PostgreSQL (same value on admin, client, and optional signaler) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Same on every service that reads encrypted columns
CHAT_DB_ENCRYPTION_KEY=

# --- Unified app (unified_app.py — single host; portal then Client or Admin) ---
# Database: always SQLite at unified_chat.db (next to unified_app.py). DATABASE_URL is ignored.
# Prefer SECRET_KEY; CLIENT_SECRET_KEY / ADMIN_SECRET_KEY still work as fallbacks.
SECRET_KEY=
CLIENT_PUBLIC_BASE_URL=https://your-app.up.railway.app

# --- Legacy split deploy: Admin (app.py) + Client (client_app.py) ---
# ADMIN_SECRET_KEY=
# CLIENT_SECRET_KEY=
# ADMIN_PUBLIC_BASE_URL=https://your-admin.up.railway.app

# Optional: dedicated signaling host (same repo, signaler_app.py). Leave empty to use client host for Socket.IO.
SIGNALING_PUBLIC_URL=https://your-signal.up.railway.app

# CORS for Socket.IO when using a separate SIGNALING_PUBLIC_URL (comma-separated allowed origins)
SOCKETIO_CORS_ORIGINS=https://your-client.up.railway.app

# Optional: scale Socket.IO across multiple workers / split client+signal (Redis URL from Railway plugin)
# REDIS_URL=
# SOCKETIO_MESSAGE_QUEUE=${REDIS_URL}

# Production cookie hardening (Railway sets RAILWAY_ENVIRONMENT=production on deploy)
# ENVIRONMENT=production
